<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor"
    tools:context=".Fragment.UserFragment">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="3dp"
        android:background="@drawable/edit_text"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView14"
            android:layout_width="15dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/yeonsung_regular"
            android:layout_weight="1"
            android:textColor="@color/textColor"
            android:text="Name" />

        <EditText
            android:id="@+id/editTextText2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColorHint="#BCBCBC"
            android:textColor="@color/textColor"
            android:background="@android:color/transparent"
            android:fontFamily="@font/lato_regular"
            android:ems="10"
            android:inputType="text"
            android:text="admin" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="3dp"
        android:background="@drawable/edit_text"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView15"
            android:layout_width="15dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/yeonsung_regular"
            android:layout_weight="1"
            android:textColor="@color/textColor"
            android:text="Email" />

        <EditText
            android:id="@+id/editTextText3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColorHint="#BCBCBC"
            android:textColor="@color/textColor"
            android:background="@android:color/transparent"
            android:fontFamily="@font/lato_regular"
            android:ems="10"
            android:inputType="textEmailAddress"
            android:text="admin@admin.com" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingTop="15dp"
        android:paddingBottom="15dp"
        android:elevation="3dp"
        android:background="@drawable/edit_text"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView16"
            android:layout_width="15dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/yeonsung_regular"
            android:layout_weight="1"
            android:textColor="@color/textColor"
            android:text="Address" />

        <EditText
            android:id="@+id/editTextText4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColorHint="#BCBCBC"
            android:textColor="@color/textColor"
            android:background="@android:color/transparent"
            android:fontFamily="@font/lato_regular"
            android:ems="10"
            android:inputType="textMultiLine"
            android:text="Address country, address city, address road, address colony, house No. address" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:layout_marginTop="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="3dp"
        android:background="@drawable/edit_text"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView17"
            android:layout_width="15dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/yeonsung_regular"
            android:layout_weight="1"
            android:textColor="@color/textColor"
            android:text="Phone" />

        <EditText
            android:id="@+id/editTextText5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColorHint="#BCBCBC"
            android:textColor="@color/textColor"
            android:background="@android:color/transparent"
            android:fontFamily="@font/lato_regular"
            android:ems="10"
            android:inputType="phone"
            android:text="92 333 444 555" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
    <!-- Button at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:background="@drawable/proceed_button"
            android:fontFamily="@font/lato_regular"
            android:text="Save Information"
            android:textColor="@color/splash1" />
    </LinearLayout>

</LinearLayout>