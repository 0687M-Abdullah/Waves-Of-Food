<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="5dp"
    app:cardBackgroundColor="@color/card_bg_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:padding="8dp">

        <ImageView
            android:id="@+id/menuImage"
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:scaleType="centerCrop"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:srcCompat="@tools:sample/avatars" />

        <TextView
            android:id="@+id/menuFoodName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Food Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@+id/menuImage"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/menuPrice"
            app:layout_constraintEnd_toStartOf="@+id/minusButton"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/menuPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$10"
            android:textSize="18sp"
            android:textColor="@color/splash1"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/menuFoodName"
            app:layout_constraintTop_toBottomOf="@+id/menuFoodName"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/plusButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/button_gradient"
            android:src="@drawable/plus"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/deleteButton" />

        <TextView
            android:id="@+id/menuQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="1"
            android:textStyle="bold"
            android:textColor="@color/text_color"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@+id/plusButton"
            app:layout_constraintBottom_toBottomOf="@+id/plusButton"
            app:layout_constraintEnd_toStartOf="@+id/plusButton" />

        <ImageButton
            android:id="@+id/minusButton"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/minus"
            android:src="@drawable/min"
            app:layout_constraintTop_toTopOf="@+id/menuQuantity"
            app:layout_constraintBottom_toBottomOf="@+id/menuQuantity"
            app:layout_constraintEnd_toStartOf="@+id/menuQuantity" />

        <ImageButton
            android:id="@+id/deleteButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="4dp"
            android:background="?android:attr/selectableItemBackground"
            android:src="@drawable/trash"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/plusButton"
            app:layout_constraintStart_toStartOf="@+id/minusButton"
            app:layout_constraintTop_toBottomOf="@+id/plusButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>