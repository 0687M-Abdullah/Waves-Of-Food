<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/signUpLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".SignUpActivity">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="90dp"
            android:layout_height="91dp"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:id="@+id/appNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waves Of Food"
            android:textSize="40sp"
            android:textColor="@color/splash1"
            android:fontFamily="@font/yeonsung_regular"
            app:layout_constraintTop_toBottomOf="@id/logoImage"
            app:layout_constraintStart_toStartOf="@id/logoImage"
            app:layout_constraintEnd_toEndOf="@id/logoImage" />

        <TextView
            android:id="@+id/taglineText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deliver Favourite Food"
            android:textSize="16sp"
            android:textColor="@color/splash2"
            app:layout_constraintTop_toBottomOf="@id/appNameText"
            app:layout_constraintStart_toStartOf="@id/appNameText"
            app:layout_constraintEnd_toEndOf="@id/appNameText" />

        <TextView
            android:id="@+id/signUpTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Up Here for your \n Admin Dashboard"
            android:textSize="20sp"
            android:textAlignment="center"
            android:textColor="@color/splash2"
            android:fontFamily="@font/yeonsung_regular"
            app:layout_constraintTop_toBottomOf="@id/taglineText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/nameInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:hint="Name"
            android:inputType="text"
            android:drawableLeft="@drawable/user"
            android:drawablePadding="15dp"
            android:paddingLeft="20dp"
            android:elevation="7dp"
            android:background="@drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/signUpTitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp" />

        <EditText
            android:id="@+id/restaurantInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:hint="Restaurant Name"
            android:inputType="text"
            android:drawableLeft="@drawable/home_icon"
            android:drawablePadding="15dp"
            android:paddingLeft="20dp"
            android:elevation="7dp"
            android:background="@drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/nameInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:hint="Email or Phone Number"
            android:inputType="textEmailAddress"
            android:drawableLeft="@drawable/mail"
            android:drawablePadding="15dp"
            android:paddingLeft="20dp"
            android:elevation="7dp"
            android:background="@drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/restaurantInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:background="@drawable/edit_text"
            android:drawableLeft="@drawable/lock"
            android:drawablePadding="15dp"
            android:elevation="7dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingLeft="20dp"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emailInput" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/createAccountButton"
            android:layout_width="172dp"
            android:layout_height="60dp"
            android:background="@drawable/button_gradient"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/passwordInput"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/loginRedirectText"
            android:text="Already Have an Account?"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/splash2"
            android:fontFamily="@font/lato_regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/createAccountButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"
            android:paddingBottom="24dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>