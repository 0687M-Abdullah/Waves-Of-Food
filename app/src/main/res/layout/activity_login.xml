<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_color">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/loginLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".LoginActivity">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="90dp"
            android:layout_height="91dp"
            android:layout_marginTop="70dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:id="@+id/appNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waves Of Food"
            android:textSize="40sp"
            android:textColor="@color/splash1"
            android:fontFamily="@font/yeonsung_regular"
            app:layout_constraintTop_toBottomOf="@id/logoImage"
            app:layout_constraintStart_toStartOf="@id/logoImage"
            app:layout_constraintEnd_toEndOf="@id/logoImage" />

        <TextView
            android:id="@+id/taglineText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deliver Favourite Food"
            android:textSize="16sp"
            android:textColor="@color/splash2"
            app:layout_constraintTop_toBottomOf="@id/appNameText"
            app:layout_constraintStart_toStartOf="@id/appNameText"
            app:layout_constraintEnd_toEndOf="@id/appNameText" />

        <TextView
            android:id="@+id/loginTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login To Your Admin \n Dashboard"
            android:textSize="20sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/splash2"
            app:layout_constraintTop_toBottomOf="@id/taglineText"
            app:layout_constraintStart_toStartOf="@id/taglineText"
            app:layout_constraintEnd_toEndOf="@id/taglineText"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:hint="Email or Phone Number"
            android:inputType="textEmailAddress"
            android:paddingLeft="20dp"
            android:elevation="7dp"
            android:background="@drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/loginTitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="325dp"
            android:layout_height="57dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingLeft="20dp"
            android:elevation="7dp"
            android:background="@drawable/edit_text"
            app:layout_constraintTop_toBottomOf="@id/emailInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/orText"
            android:text="Or"
            android:textColor="@color/text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/passwordInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/continueWithText"
            android:text="Continue With"
            android:textColor="@color/text_color"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/yeonsung_regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/orText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/facebookButton"
            android:layout_width="152dp"
            android:layout_height="57dp"
            android:text="Facebook"
            android:drawableLeft="@drawable/facebook"
            android:drawablePadding="6dp"
            android:background="@drawable/white_button"
            android:textColor="@color/text_color"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/continueWithText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/googleButton"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/googleButton"
            android:layout_width="152dp"
            android:layout_height="57dp"
            android:text="Google"
            android:drawableLeft="@drawable/google"
            android:drawablePadding="6dp"
            android:background="@drawable/white_button"
            android:textColor="@color/text_color"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/continueWithText"
            app:layout_constraintStart_toEndOf="@id/facebookButton"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/loginButton"
            android:layout_width="157dp"
            android:layout_height="57dp"
            android:text="Login"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:background="@drawable/button_gradient"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/googleButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

        <TextView
            android:id="@+id/createAccountText"
            android:text="Don't Have Account?"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/splash2"
            android:fontFamily="@font/lato_regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/loginButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:paddingBottom="24dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>